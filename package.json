{
  "name": "ecommerce-tech",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo de ecommerce de productos tecnológicos - Next.js 14 + Fastify + PostgreSQL + Redis + Stripe",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @ecommerce/api prisma migrate dev",
    "db:generate": "pnpm --filter @ecommerce/api prisma generate",
    "db:seed": "pnpm --filter @ecommerce/api prisma:seed",
    "db:studio": "pnpm --filter @ecommerce/api prisma studio"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "neverBuiltDependencies": ["unrs-resolver"]
  }
}
