# ==========================================
# Base de Datos
# ==========================================
POSTGRES_PASSWORD=tu_password_postgres_seguro
REDIS_PASSWORD=tu_password_redis_seguro
DATABASE_URL=postgresql://ecommerce:${POSTGRES_PASSWORD}@localhost:5432/ecommerce?schema=public
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0
# Opcional: poblar datos demo en Railway para pruebas iniciales
SEED_DATABASE=false

# ==========================================
# Autenticación JWT
# ==========================================
JWT_SECRET=tu_jwt_secret_super_seguro_minimo_32_caracteres
JWT_REFRESH_SECRET=tu_refresh_secret_super_seguro_minimo_32_caracteres

# ==========================================
# Cifrado AES (teléfono y MFA)
# ==========================================
AES_PHONE_KEY=tu_clave_aes_32_caracteres_para_cifrar_phone
MFA_SECRET_KEY=tu_clave_aes_32_caracteres_para_cifrar_mfa

# ==========================================
# CSRF
# ==========================================
CSRF_SECRET=tu_csrf_secret_32_caracteres

# ==========================================
# Stripe (Pagos)
# ==========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Hash SHA-384 de stripe.js para monitoreo de integridad (anti-Magecart)
# Obtener con: curl -s https://js.stripe.com/v3/ | openssl dgst -sha384 -binary | openssl base64
STRIPE_JS_HASH=sha384-...

# ==========================================
# Cloudinary (Imágenes)
# ==========================================
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ==========================================
# Email (Resend)
# ==========================================
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@tu-dominio.com

# ==========================================
# Monitoring y Alertas (Sentry)
# ==========================================
SENTRY_DSN=https://...@...ingest.sentry.io/...
SENTRY_ENVIRONMENT=development

# ==========================================
# Cloudflare (WAF / IP blocking)
# ==========================================
CLOUDFLARE_API_TOKEN=tu_cloudflare_api_token
CLOUDFLARE_ZONE_ID=tu_zone_id

# ==========================================
# Alertas Slack
# ==========================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ==========================================
# Servidor / CORS / Rate Limiting
# ==========================================
CORS_ORIGIN=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NODE_ENV=development
PORT=4000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
